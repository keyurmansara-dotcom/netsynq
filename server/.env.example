PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/netsynq

# JWT / auth secrets
JWT_SECRET=replace-with-a-long-random-secret
ACCESS_TOKEN_SECRET=replace-with-a-long-random-secret
REFRESH_TOKEN_SECRET=replace-with-a-long-random-secret

# Frontend URL used in password reset links
CLIENT_URL=http://localhost:5173

# SMTP settings required to send password reset emails
# Only SMTP_USER + SMTP_PASS are required (defaults use Gmail smtp.gmail.com:587)
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Optional overrides
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
MAIL_FROM=NetSynq <your-email@gmail.com>
